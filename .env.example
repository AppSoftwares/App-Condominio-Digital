# backend/.env.example
# Copia este archivo como .env y rellena los valores reales
# NUNCA subas .env a git

# Base de datos
DATABASE_URL="postgresql://user:password@localhost:5432/condominio_db"

# JWT — genera con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET="REEMPLAZA_CON_64_BYTES_RANDOM"
JWT_REFRESH_SECRET="REEMPLAZA_CON_64_BYTES_RANDOM_DIFERENTE"

# Redis
REDIS_URL="redis://localhost:6379"

# App
NODE_ENV="development"
PORT=4000
WEB_URL="http://localhost:3000"

# Storage (comprobantes de pago)
SUPABASE_URL="https://xxxx.supabase.co"
SUPABASE_KEY="tu_service_role_key"
# O si usas S3:
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_BUCKET_NAME=""
# AWS_REGION="us-east-1"

# Email
RESEND_API_KEY="re_xxxx"
EMAIL_FROM="noreply@tucondominio.com"

# WhatsApp (Twilio)
TWILIO_ACCOUNT_SID="ACxxxx"
TWILIO_AUTH_TOKEN="xxxx"
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"

# Firebase (push notifications)
FIREBASE_PROJECT_ID="tu-proyecto"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk@tu-proyecto.iam.gserviceaccount.com"
